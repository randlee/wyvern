---
name: rust-qa-assignment
version: 1.0.0
description: Render a fenced-JSON assignment for rust-qa-agent.
format: json
required_variables:
  - review_mode
  - worktree_path
  - review_targets
optional_variables:
  - fmt
  - clippy
  - tests
  - coverage
  - baseline_ref
  - artifact_regeneration_required
  - artifact_commands
  - round_limit
  - changed_files
  - carry_forward_findings_json
  - triage_records
  - notes
defaults:
  fmt: true
  clippy: true
  tests: true
  coverage: ""
  baseline_ref: ""
  artifact_regeneration_required: false
  artifact_commands: ""
  round_limit: false
  changed_files: []
  carry_forward_findings_json: "[]"
  triage_records: []
  notes: ""
---
{
  "worktree_path": "{{ worktree_path }}",
  "review_mode": "{{ review_mode }}",
  "review_targets": [{% for target in review_targets %}"{{ target }}"{% if not loop.last %}, {% endif %}{% endfor %}],
  "run_checks": {
    "fmt": {% if fmt %}true{% else %}false{% endif %},
    "clippy": {% if clippy %}true{% else %}false{% endif %},
    "tests": {% if tests %}true{% else %}false{% endif %},
    "coverage": {% if coverage == true %}true{% elif coverage == false %}false{% elif review_mode == "phase_end" %}true{% else %}false{% endif %}
  },
  "baseline_ref": "{{ baseline_ref }}",
  "artifact_regeneration_required": {% if artifact_regeneration_required %}true{% else %}false{% endif %},
  "artifact_commands": "{{ artifact_commands }}",
  "round_limit": {% if round_limit %}true{% else %}false{% endif %},
  "changed_files": [{% for file in changed_files %}"{{ file }}"{% if not loop.last %}, {% endif %}{% endfor %}],
  "triage_records": [{% for record in triage_records %}"{{ record }}"{% if not loop.last %}, {% endif %}{% endfor %}],
  "carry_forward_findings": {{ carry_forward_findings_json }},
  "notes": "Checklist: scan for infallible Result<T, E> shapes; check for Ok(x) as the sole return path in Result-returning functions; for deletion sprints, search the whole workspace for every removed legacy construct family named in the sprint doc, not just touched files.{% if notes %} {{ notes }}{% endif %}"
}
