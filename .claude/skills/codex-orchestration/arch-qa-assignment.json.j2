---
name: arch-qa-assignment
version: 1.0.0
description: Render a fenced-JSON assignment for arch-qa.
format: json
required_variables:
  - review_mode
  - worktree_path
  - branch
  - review_targets
  - reference_docs
optional_variables:
  - commit
  - phase
  - sprint
  - sprint_doc
  - round_limit
  - changed_files
  - carry_forward_findings_json
  - triage_records
  - notes
defaults:
  commit: ""
  phase: ""
  sprint: ""
  sprint_doc: ""
  round_limit: false
  changed_files: []
  carry_forward_findings_json: "[]"
  triage_records: []
  notes: ""
---
{
  "review_mode": "{{ review_mode }}",
  "worktree_path": "{{ worktree_path }}",
  "branch": "{{ branch }}",
  "commit": "{{ commit }}",
  "scope": {
    "phase": {% if phase %}"{{ phase }}"{% else %}null{% endif %},
    "sprint": {% if sprint %}"{{ sprint }}"{% else %}null{% endif %}
  },
  "authoritative_sprint_doc": {% if sprint_doc %}"{{ sprint_doc }}"{% else %}null{% endif %},
  "review_targets": [{% for target in review_targets %}"{{ target }}"{% if not loop.last %}, {% endif %}{% endfor %}],
  "reference_docs": [{% for doc in reference_docs %}"{{ doc }}"{% if not loop.last %}, {% endif %}{% endfor %}],
  "round_limit": {% if round_limit %}true{% else %}false{% endif %},
  "changed_files": [{% for file in changed_files %}"{{ file }}"{% if not loop.last %}, {% endif %}{% endfor %}],
  "triage_records": [{% for record in triage_records %}"{{ record }}"{% if not loop.last %}, {% endif %}{% endfor %}],
  "carry_forward_findings": {{ carry_forward_findings_json }},
  "notes": "{{ notes }}"
}
