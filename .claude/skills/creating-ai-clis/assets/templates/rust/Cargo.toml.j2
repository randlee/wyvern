---
required_variables:
  - package_name
defaults:
  version: "0.1.0"
metadata:
  language: rust
  template_kind: project-file
  skill: creating-ai-clis
---
[package]
name = "{{ package_name }}"
version = "{{ version }}"
edition = "2024"

[dependencies]
clap = { version = "4.5", features = ["derive"] }
serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"
